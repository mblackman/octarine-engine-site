<!DOCTYPE html>
<html lang="en" data-theme="octarine">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default("Octarine Engine — The Color of Magic, in Your Code") }}</title>
  <meta name="description" content="{{ description | default('A lightweight C++20 2D game engine. Lua-first scripting, archetype ECS, SDL3 rendering, and an integrated ImGui editor. MIT licensed.') }}">
  <meta property="og:title"       content="{{ title | default('Octarine Engine') }}">
  <meta property="og:description" content="{{ description | default('A lightweight C++20 2D game engine with Lua-first scripting and an integrated editor.') }}">
  <meta property="og:type"        content="website">
  <meta property="og:url"         content="https://engine.octarine.club">
  <meta name="twitter:card"       content="summary_large_image">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="{{ '/styles/main.css' | url }}">

  <!-- Inline SVG favicon — octarine sparkle -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text x='50' y='50' font-size='78' text-anchor='middle' dominant-baseline='central' fill='%23A855F7'>✦</text></svg>">
</head>
<body class="min-h-screen">

  <!-- Starfield canvas — fixed behind all content -->
  <canvas id="starfield" class="fixed inset-0 w-full h-full pointer-events-none" style="z-index:0"></canvas>

  <!-- Sticky navigation -->
  <nav class="fixed inset-x-0 top-0 z-50 flex items-center justify-between px-6 py-3"
       style="background: oklch(8% 0.02 280 / 0.85); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-bottom: 1px solid oklch(65% 0.28 305 / 0.12);">
    <a href="#" class="font-display text-primary text-lg tracking-wide"
       style="text-shadow: 0 0 20px oklch(65% 0.28 305 / 0.5);">
      Octarine
    </a>
    <div class="hidden md:flex items-center gap-7 text-sm" style="color: oklch(62% 0.05 280);">
      <a href="#features"   class="hover:text-primary   transition-colors duration-200">Features</a>
      <a href="#stack"      class="hover:text-accent    transition-colors duration-200">Stack</a>
      <a href="#code"       class="hover:text-secondary transition-colors duration-200">Example</a>
      <a href="#get-started" class="hover:text-accent   transition-colors duration-200">Get Started</a>
    </div>
    <a href="https://github.com/mblackman/Octarine-Engine"
       target="_blank" rel="noopener noreferrer"
       class="btn btn-sm btn-outline btn-primary font-display text-xs tracking-wider">
      GitHub ↗
    </a>
  </nav>

  <!-- Page content — padded so first section clears the fixed nav -->
  <div class="relative" style="z-index:1; padding-top: 52px;">
    {{ content | safe }}
  </div>

  <script src="{{ '/assets/js/stars.js' | url }}"></script>
</body>
</html>
