════════════════════════════════════════════════════════════════ #}
<section class="py-28 px-6" id="features">
  <div class="max-w-6xl mx-auto">

    <div class="text-center mb-20">
      <div class="text-primary text-2xl mb-4 opacity-50" aria-hidden="true">✦</div>
      <h2 class="text-4xl md:text-5xl font-display glow-octarine mb-4">
        Spells in the Toolkit
      </h2>
      <p class="italic" style="color: oklch(55% 0.05 280);">
        "Every wizard needs their implements"
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

      <div class="card bg-base-200 card-magical p-8">
        <div class="text-5xl mb-5" aria-hidden="true">🌙</div>
        <h3 class="text-2xl font-display mb-3" style="color: oklch(72% 0.26 135);">Lua-First Scripting</h3>
        <p class="leading-relaxed" style="color: oklch(78% 0.04 280);">
          Write all your game logic in Lua 5.4 — no C++ required. Hot-reload scripts
          while the engine runs, and use auto-generated EmmyLua stubs for full IDE
          autocomplete. The C++ core stays out of your way until you need raw speed.
        </p>
      </div>

      <div class="card bg-base-200 card-magical p-8">
        <div class="text-5xl mb-5" aria-hidden="true">⚡</div>
        <h3 class="text-2xl font-display mb-3" style="color: oklch(72% 0.26 135);">Archetype ECS</h3>
        <p class="leading-relaxed" style="color: oklch(78% 0.04 280);">
          A custom archetype-based Entity Component System with cache-efficient SoA
          storage. Each component type is stored contiguously so systems iterate only
          the data they need. Compose entities from components — no inheritance, no
          virtual dispatch.
        </p>
      </div>

      <div class="card bg-base-200 card-magical p-8">
        <div class="text-5xl mb-5" aria-hidden="true">🔮</div>
        <h3 class="text-2xl font-display mb-3" style="color: oklch(72% 0.26 135);">Integrated ImGui Editor</h3>
        <p class="leading-relaxed" style="color: oklch(78% 0.04 280);">
          Dear ImGui is baked in, not bolted on. Inspect and live-edit entities while
          the game runs, execute Lua from an in-editor console, and track frame times
          in the profiler. Dockable layout with persistent window arrangement.
        </p>
      </div>

      <div class="card bg-base-200 card-magical p-8">
        <div class="text-5xl mb-5" aria-hidden="true">🌍</div>
        <h3 class="text-2xl font-display mb-3" style="color: oklch(72% 0.26 135);">Multi-Platform Shipping</h3>
        <p class="leading-relaxed" style="color: oklch(78% 0.04 280);">
          One CMake project targets Windows, Linux, macOS, and Android. SDL3 handles
          the platform abstraction; vcpkg handles the dependency graph. A unified
          pipeline produces installers, archives, DMGs, and APKs.
        </p>
      </div>

    </div>
  </div>
</section>


