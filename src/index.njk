<section class="py-28 px-6" id="code">
  <div class="max-w-4xl mx-auto">

    <div class="text-center mb-16">
      <div class="text-secondary text-2xl mb-4 opacity-50" aria-hidden="true">✦</div>
      <h2 class="text-4xl md:text-5xl font-display mb-4"
          style="color: oklch(72% 0.26 135);">
        See the Spell
      </h2>
      <p class="italic" style="color: oklch(55% 0.05 280);">
        "A complete moving player entity. The engine handles the rest."
      </p>
    </div>

    <div class="card card-magical overflow-hidden" style="background: oklch(6% 0.02 280);">
      {# Faux terminal title bar #}
      <div class="flex items-center gap-2 px-4 py-3"
           style="background: oklch(13% 0.03 280); border-bottom: 1px solid oklch(65% 0.28 305 / 0.15);">
        <div class="w-3 h-3 rounded-full" style="background: oklch(62% 0.26 25 / 0.7);"></div>
        <div class="w-3 h-3 rounded-full" style="background: oklch(80% 0.20 70 / 0.7);"></div>
        <div class="w-3 h-3 rounded-full" style="background: oklch(65% 0.22 150 / 0.7);"></div>
        <span class="ml-3 text-xs font-mono" style="color: oklch(45% 0.04 280);">
          game/scenes/world.lua
        </span>
      </div>

      <div class="p-6 overflow-x-auto">
{% highlight "lua" %}
-- bind movement actions to keys
input.bind("move_right", "d")
input.bind("move_left",  "a")
input.bind("move_up",    "w")
input.bind("move_down",  "s")

-- spawn the player entity
load_entity({
    tag  = "player",
    name = "Player",
    components = {
        transform     = { position = { x = 400, y = 300 } },
        sprite        = { texture_asset_id = "player", width = 32, height = 32, layer = 2 },
        rigidbody     = { velocity = { x = 0, y = 0 } },
        camera_follow = {},

        -- script component: on_update runs every frame
        script = {
            speed = 120,
            on_update = function(self, entity, dt)
                local dx, dy = 0, 0
                if input.is_action_down("move_right") then dx = dx + 1 end
                if input.is_action_down("move_left")  then dx = dx - 1 end
                if input.is_action_down("move_up")    then dy = dy - 1 end
                if input.is_action_down("move_down")  then dy = dy + 1 end

                local rb = registry.get_rigidbody(entity)
                if dx ~= 0 or dy ~= 0 then
                    local len = math.sqrt(dx * dx + dy * dy)
                    rb.velocity.x = (dx / len) * self.speed
                    rb.velocity.y = (dy / len) * self.speed
                else
                    rb.velocity.x = 0
                    rb.velocity.y = 0
                end
            end,
        },
    },
})
{% endhighlight %}
      </div>
    </div>

  </div>
</section>


